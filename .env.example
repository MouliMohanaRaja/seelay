# Copy to .env.local and fill in real values. .env.local is gitignored —
# a real key must NEVER appear in any committed file (see CLAUDE.md).

# Supabase (created in PLAN.md step 1.1; used from 1.2 onward)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# TMDB — entity resolution source (PLAN.md step 1.3)
TMDB_API_KEY=

# Intelligent Fallback (T4) — vendor-neutral by design (ARCHITECTURE.md).
# Provider is an env-level decision: gemini | claude | ollama | ...
# Prefer free-tier or local providers during the MVP.
FALLBACK_LLM_PROVIDER=
FALLBACK_LLM_MODEL=
FALLBACK_LLM_API_KEY=
